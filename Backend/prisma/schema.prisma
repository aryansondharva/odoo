generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CUSTOMER
}
enum ProductStatus {
  AVAILABLE
  RESERVED
  RENTED
  UNDER_REPAIR
  OUT_OF_STOCK
}
enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  CONFIRMED
  READY_FOR_PICKUP
  PICKED_UP
  ACTIVE
  RETURN_REQUESTED
  RETURNED
  COMPLETED
  CANCELLED
}
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUND
}
enum DepositStatus {
  HELD
  PARTIALLY_REFUNDED
  REFUNDED
  FORFEITED
}
enum ReturnCondition {
  GOOD
  DAMAGED
  MISSING_PARTS
  REPAIR_REQUIRED
}
enum PickupType {
  STORE_PICKUP
  HOME_DELIVERY
}
enum FeeType {
  PERCENTAGE
  FIXED
}
enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String
  phone String?
  avatar String?
  role UserRole @default(CUSTOMER)
  isVerified Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  addresses Address[]
  cart Cart?
  quotations Quotation[]
  orders Order[]
  notifications Notification[]
  refreshTokens RefreshToken[]
  @@index([email])
}

model RefreshToken {
  id String @id @default(uuid())
  token String @unique
  userId String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Address {
  id String @id @default(uuid())
  userId String
  fullName String
  phone String
  addressLine1 String
  addressLine2 String?
  city String
  state String
  country String
  postalCode String
  isDefault Boolean @default(false)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
  @@index([userId])
}

model Category {
  id String @id @default(uuid())
  name String @unique
  description String?
  image String?
  products Product[]
  @@index([name])
}

model Product {
  id String @id @default(uuid())
  categoryId String
  name String
  description String?
  sku String @unique
  brand String?
  manufacturer String?
  pricePerHour Decimal @db.Decimal(12, 2)
  pricePerDay Decimal @db.Decimal(12, 2)
  pricePerWeek Decimal @db.Decimal(12, 2)
  pricePerMonth Decimal @db.Decimal(12, 2)
  depositAmount Decimal @db.Decimal(12, 2)
  stock Int @default(0)
  availableStock Int @default(0)
  status ProductStatus @default(AVAILABLE)
  thumbnail String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants ProductVariant[]
  cartItems CartItem[]
  orderItems OrderItem[]
  @@index([categoryId])
  @@index([status])
}

model ProductVariant {
  id String @id @default(uuid())
  productId String
  color String?
  size String?
  serialNumber String? @unique
  barcode String? @unique
  condition ReturnCondition @default(GOOD)
  status ProductStatus @default(AVAILABLE)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderItems OrderItem[]
  @@index([productId])
  @@index([barcode])
}

model RentalPeriod {
  id String @id @default(uuid())
  name String @unique
  duration Int
  unit String
  cartItems CartItem[]
  orders Order[]
}

model Cart {
  id String @id @default(uuid())
  userId String @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id String @id @default(uuid())
  cartId String
  productId String
  variantId String?
  rentalPeriodId String
  quantity Int @default(1)
  price Decimal @db.Decimal(12, 2)
  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  rentalPeriod RentalPeriod @relation(fields: [rentalPeriodId], references: [id], onDelete: Restrict)
  @@index([cartId])
  @@index([productId])
}

model Quotation {
  id String @id @default(uuid())
  userId String
  quotationNumber String @unique
  status OrderStatus @default(DRAFT)
  subtotal Decimal @db.Decimal(12, 2)
  deposit Decimal @db.Decimal(12, 2)
  tax Decimal @default(0) @db.Decimal(12, 2)
  total Decimal @db.Decimal(12, 2)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  orders Order[]
  @@index([userId])
}

model Order {
  id String @id @default(uuid())
  userId String
  addressId String?
  quotationId String? @unique
  rentalPeriodId String
  status OrderStatus @default(PENDING_PAYMENT)
  pickupType PickupType
  startDate DateTime
  endDate DateTime
  subtotal Decimal @db.Decimal(12, 2)
  deposit Decimal @db.Decimal(12, 2)
  lateFee Decimal @default(0) @db.Decimal(12, 2)
  tax Decimal @default(0) @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total Decimal @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)
  address Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)
  quotation Quotation? @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  rentalPeriod RentalPeriod @relation(fields: [rentalPeriodId], references: [id], onDelete: Restrict)
  items OrderItem[]
  payments Payment[]
  securityDeposit SecurityDeposit?
  pickup Pickup?
  returnRecord Return?
  invoice Invoice?
  @@index([userId])
  @@index([addressId])
  @@index([rentalPeriodId])
}

model OrderItem {
  id String @id @default(uuid())
  orderId String
  productId String
  variantId String?
  quantity Int
  price Decimal @db.Decimal(12, 2)
  deposit Decimal @db.Decimal(12, 2)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  @@index([orderId])
  @@index([productId])
}

model Payment {
  id String @id @default(uuid())
  orderId String
  method String
  transactionId String? @unique
  amount Decimal @db.Decimal(12, 2)
  status PaymentStatus @default(PENDING)
  paidAt DateTime?
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@index([orderId])
  @@index([transactionId])
}

model SecurityDeposit {
  id String @id @default(uuid())
  orderId String @unique
  amount Decimal @db.Decimal(12, 2)
  deductedAmount Decimal @default(0) @db.Decimal(12, 2)
  refundAmount Decimal @default(0) @db.Decimal(12, 2)
  status DepositStatus @default(HELD)
  processedAt DateTime?
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Pickup {
  id String @id @default(uuid())
  orderId String @unique
  pickupDate DateTime
  actualPickupDate DateTime?
  employeeName String?
  status OrderStatus @default(READY_FOR_PICKUP)
  notes String?
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Return {
  id String @id @default(uuid())
  orderId String @unique
  returnDate DateTime
  actualReturnDate DateTime?
  condition ReturnCondition @default(GOOD)
  damageReport String?
  missingAccessories String?
  lateFee Decimal @default(0) @db.Decimal(12, 2)
  status OrderStatus @default(RETURN_REQUESTED)
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Invoice {
  id String @id @default(uuid())
  orderId String @unique
  invoiceNumber String @unique
  subtotal Decimal @db.Decimal(12, 2)
  deposit Decimal @db.Decimal(12, 2)
  lateFee Decimal @default(0) @db.Decimal(12, 2)
  tax Decimal @default(0) @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total Decimal @db.Decimal(12, 2)
  pdfUrl String?
  generatedAt DateTime @default(now())
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  @@index([invoiceNumber])
}

model Notification {
  id String @id @default(uuid())
  userId String
  title String
  message String
  type String
  isRead Boolean @default(false)
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Settings {
  id String @id @default(uuid())
  defaultDepositType FeeType @default(PERCENTAGE)
  defaultDepositValue Decimal @default(0) @db.Decimal(12, 2)
  lateFeeType FeeType @default(FIXED)
  lateFeeValue Decimal @default(0) @db.Decimal(12, 2)
  gracePeriod Int @default(0)
  maxLateFee Decimal? @db.Decimal(12, 2)
  currency String @default("INR")
  taxPercentage Decimal @default(0) @db.Decimal(5, 2)
}

model Coupon {
  id String @id @default(uuid())
  code String @unique
  discountType DiscountType
  discountValue Decimal @db.Decimal(12, 2)
  minimumAmount Decimal @default(0) @db.Decimal(12, 2)
  startDate DateTime
  endDate DateTime
  isActive Boolean @default(true)
  @@index([code])
}
